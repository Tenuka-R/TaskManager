      </component>
      <component id="d9013" class="javax.swing.JLabel" binding="sortText">
        <constraints>
          <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Sort by:"/>
        </properties>
      </component>
      <component id="572a5" class="javax.swing.JComboBox" binding="sortOptions">

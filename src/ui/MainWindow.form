        </constraints>
        <properties>
          <text value="Enter text to search for..."/>
        </properties>
      </component>
      <component id="931fb" class="javax.swing.JButton" binding="clearSearch">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
